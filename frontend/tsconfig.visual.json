{
  // The Playwright visual-fidelity harness (PROJECT-STANDARDS §14.2).
  //
  // A project of its own rather than a folder inside tsconfig.node.json, because
  // it straddles both of that file's assumptions: it imports app source (which is
  // written for bundler resolution, no file extensions) and it runs in Node while
  // serializing callbacks into the browser (so it needs DOM lib alongside node types).
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.visual.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode — matches tsconfig.app.json so app imports resolve identically */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["playwright.config.ts", "visual"]
}
