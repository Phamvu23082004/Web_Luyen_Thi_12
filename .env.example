# PostgreSQL connection string (Prisma). Matches docker-compose's postgres service.
DATABASE_URL=postgresql://onthi12:onthi12@localhost:5432/onthi12?schema=public

# Redis cache connection.
REDIS_URL=redis://localhost:6379

# RabbitMQ connection (async AI parsing + dashboard queues).
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Gemini API key — backend only, never exposed to the frontend.
GEMINI_API_KEY=your-gemini-api-key-here

# JWT access token signing secret.
JWT_SECRET=your-jwt-secret-here

# JWT access token lifetime — kept short (stateless verification, no revocation).
JWT_EXPIRES_IN=15m

# JWT refresh token signing secret — must be distinct from JWT_SECRET so an access
# token can't be replayed as a refresh token or vice versa.
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# JWT refresh token lifetime — stored hashed in Redis, rotated on every /api/auth/refresh call.
JWT_REFRESH_EXPIRES_IN=7d

# Runtime environment.
NODE_ENV=development

# Email provider API key (for AUTH-03 password reset emails).
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key-here
