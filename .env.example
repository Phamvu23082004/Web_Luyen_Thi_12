# PostgreSQL connection string (Prisma). Matches docker-compose's postgres service.
DATABASE_URL=postgresql://onthi12:onthi12@localhost:5432/onthi12?schema=public

# Redis cache connection.
REDIS_URL=redis://localhost:6379

# RabbitMQ connection (async AI parsing + dashboard queues).
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Gemini API key — backend only, never exposed to the frontend.
GEMINI_API_KEY=your-gemini-api-key-here

# JWT access token signing secret.
JWT_SECRET=your-jwt-secret-here

# JWT access token lifetime — kept short (stateless verification, no revocation).
JWT_EXPIRES_IN=15m

# JWT refresh token signing secret — must be distinct from JWT_SECRET so an access
# token can't be replayed as a refresh token or vice versa.
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# JWT refresh token lifetime — stored hashed in Redis, rotated on every /api/auth/refresh call.
JWT_REFRESH_EXPIRES_IN=7d

# Login rate limiting — sliding-window length in seconds (per IP and per account).
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Max login attempts per client IP per window. Lenient on purpose: a whole class
# behind one school NAT egress IP logs in at exam time (NFR-01/05), so a tight
# per-IP cap would lock out legitimate students.
LOGIN_RATE_LIMIT_IP_MAX=30

# Max login attempts per account (email) per window. Strict — this is the actual
# brute-force throttle, and it holds even when the attacker rotates IPs.
LOGIN_RATE_LIMIT_ACCOUNT_MAX=5

# Runtime environment.
NODE_ENV=development

# Email provider API key (for AUTH-03 password reset emails).
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key-here

# Resend's shared test sender. Without a verified custom domain, Resend only
# delivers to the account's own registered email — relevant for the manual smoke test.
EMAIL_FROM_ADDRESS=onboarding@resend.dev

# Password reset link validity window, in minutes.
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Frontend base URL, used to build the password reset link. Becomes the real
# domain in production (Epic 6).
FRONTEND_BASE_URL=http://localhost:5173

# Local blob root behind the AD-15 source_file_url abstraction; `/app/storage`
# inside the containers (shared api+worker volume).
STORAGE_ROOT=./storage

# Max exam-PDF upload size in bytes (20 MB).
EXAM_PDF_MAX_BYTES=20971520

# Parse-enqueue rate limiting — sliding-window length in seconds (per teacher).
AI_PARSE_RATE_LIMIT_WINDOW_SECONDS=3600

# Max parse-enqueue requests per teacher per window; bounds Gemini daily-quota burn (NFR-09).
AI_PARSE_RATE_LIMIT_MAX=20
